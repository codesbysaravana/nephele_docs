{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nephele.ai/schemas/knowledge-graph.schema.json",
  "title": "Nephele Knowledge Graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["graph_id", "version", "domains", "concepts", "edges"],
  "properties": {
    "graph_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Domain" }
    },
    "concepts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/ConceptNode" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/RelationshipEdge" }
    }
  },
  "$defs": {
    "Domain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["domain_id", "name", "entry_concepts"],
      "properties": {
        "domain_id": {
          "type": "string",
          "minLength": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "entry_concepts": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "ConceptNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "concept_id",
        "concept_name",
        "domain_id",
        "difficulty",
        "description",
        "tags",
        "importance_weight",
        "estimated_question_count"
      ],
      "properties": {
        "concept_id": {
          "type": "string",
          "minLength": 1
        },
        "concept_name": {
          "type": "string",
          "minLength": 1
        },
        "domain_id": {
          "type": "string",
          "minLength": 1
        },
        "difficulty": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "importance_weight": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "estimated_question_count": {
          "type": "integer",
          "minimum": 0
        },
        "question_ids": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "common_failures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "common_misconceptions": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "future_state": {
          "$ref": "#/$defs/FutureConceptState"
        },
        "metadata": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "FutureConceptState": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mastery_score": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 100
        },
        "confidence": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "attempt_count": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "interview_history": {
          "type": "array",
          "items": { "$ref": "#/$defs/InterviewHistoryItem" }
        }
      }
    },
    "InterviewHistoryItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["session_id", "timestamp"],
      "properties": {
        "session_id": {
          "type": "string"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "outcome": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "RelationshipEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["edge_id", "source_id", "target_id", "relationship_type"],
      "properties": {
        "edge_id": {
          "type": "string",
          "minLength": 1
        },
        "source_id": {
          "type": "string",
          "minLength": 1
        },
        "target_id": {
          "type": "string",
          "minLength": 1
        },
        "relationship_type": {
          "type": "string",
          "enum": ["prerequisite", "related", "cross_domain"]
        },
        "label": {
          "type": "string"
        },
        "directionality": {
          "type": "string",
          "enum": ["directed", "undirected"]
        },
        "metadata": {
          "$ref": "#/$defs/FutureEdgeMetadata"
        }
      }
    },
    "FutureEdgeMetadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "relationship_strength": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "traversal_frequency": {
          "type": ["integer", "null"],
          "minimum": 0
        },
        "success_rate": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        },
        "failure_rate": {
          "type": ["number", "null"],
          "minimum": 0,
          "maximum": 1
        }
      }
    }
  }
}
